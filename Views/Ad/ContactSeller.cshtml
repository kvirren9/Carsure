@model Carsure.Models.ContactSellerViewModel

@{
    ViewData["Title"] = "Kontakta säljaren";
}

<section class="ads-page">
    <div class="ads-hero">
        <div>
            <span class="ads-eyebrow">Kontakt</span>
            <h1 class="ads-title">Kontakta säljaren</h1>
            <p class="ads-subtitle">Angående: @Model.AdTitle</p>
        </div>
    </div>

    <div class="contact-seller-wrapper">
        <div class="contact-seller-card">

            <div class="contact-seller-info">
                <div class="contact-seller-info__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor"
                         viewBox="0 0 16 16">
                        <path
                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
                    </svg>
                </div>
                <div>
                    <p class="contact-seller-info__label">Säljare</p>
                    <p class="contact-seller-info__value">@Model.SellerName</p>
                </div>
            </div>

            <div class="contact-seller-info">
                <div class="contact-seller-info__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor"
                         viewBox="0 0 16 16">
                        <path
                        d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z" />
                    </svg>
                </div>
                <div>
                    <p class="contact-seller-info__label">E-post skickas till</p>
                    <p class="contact-seller-info__value">@Model.SellerEmail</p>
                </div>
            </div>

            <hr class="contact-seller-divider" />

            <form asp-controller="Ad" asp-action="ContactSeller" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AdId" />
                <input type="hidden" asp-for="AdTitle" />
                <input type="hidden" asp-for="SellerName" />
                <input type="hidden" asp-for="SellerEmail" />
                <input type="hidden" asp-for="SenderName" />
                <input type="hidden" asp-for="SenderEmail" />

                <div asp-validation-summary="All" class="alert alert-danger"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="form-group mb-3">
                    <label asp-for="Subject" class="form-label fw-semibold"></label>
                    <input asp-for="Subject" class="form-control" placeholder="T.ex. Fråga om priset" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Message" class="form-label fw-semibold"></label>
                    <textarea asp-for="Message" class="form-control" rows="6"
                              placeholder="Skriv ditt meddelande här..."></textarea>
                    <span asp-validation-for="Message" class="text-danger small"></span>
                </div>

                <div class="contact-seller-sender">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         viewBox="0 0 16 16">
                        <path
                        d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z" />
                    </svg>
                    Meddelandet skickas från <strong>@Model.SenderName</strong> (@Model.SenderEmail)
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1"
                             viewBox="0 0 16 16">
                            <path
                            d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z" />
                        </svg>
                        Skicka meddelande
                    </button>
                    <a asp-controller="Ad" asp-action="Details" asp-route-id="@Model.AdId"
                       class="btn btn-outline-secondary">
                        Avbryt
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
