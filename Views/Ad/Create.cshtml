@model Carsure.Models.CreateAdViewModel

@{
    ViewData["Title"] = "Skapa annons";
}

<section class="ads-page">

    <div class="ads-hero">
        <div>
            <span class="ads-eyebrow">Ny annons</span>
            <h1 class="ads-title">Skapa bilannons</h1>
            <p class="ads-subtitle">Fyll i uppgifterna om bilen och annonsen nedan.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <form asp-controller="Ad" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color:#0f172a;">🚗 Biluppgifter</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="RegNumber" class="form-label fw-semibold"></label>
                            <input asp-for="RegNumber" class="form-control text-uppercase" placeholder="t.ex. ABC123"
                                   maxlength="10" />
                            <span asp-validation-for="RegNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label fw-semibold"></label>
                            <input asp-for="Brand" class="form-control" placeholder="t.ex. Volvo" />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label fw-semibold"></label>
                            <input asp-for="Model" class="form-control" placeholder="t.ex. V70" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Year" class="form-label fw-semibold"></label>
                            <input asp-for="Year" type="number" class="form-control" min="1900" max="2100"
                                   placeholder="t.ex. 2020" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MileAge" class="form-label fw-semibold"></label>
                            <input asp-for="MileAge" class="form-control" placeholder="t.ex. 45000" />
                            <span asp-validation-for="MileAge" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FuelType" class="form-label fw-semibold"></label>
                            <select asp-for="FuelType" class="form-select">
                                <option value="">-- Välj bränsletyp --</option>
                                <option value="Bensin">Bensin</option>
                                <option value="Diesel">Diesel</option>
                                <option value="El">El</option>
                                <option value="Hybrid">Hybrid</option>
                                <option value="Laddhybrid">Laddhybrid</option>
                                <option value="Gas">Gas</option>
                                <option value="Etanol">Etanol</option>
                            </select>
                            <span asp-validation-for="FuelType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Transmission" class="form-label fw-semibold"></label>
                            <select asp-for="Transmission" class="form-select">
                                <option value="">-- Välj växellåda --</option>
                                <option value="Manuell">Manuell</option>
                                <option value="Automat">Automat</option>
                            </select>
                            <span asp-validation-for="Transmission" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h5 class="fw-bold mb-4" style="color:#0f172a;">📋 Annonsuppgifter</h5>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Annonstitel</label>
                        <input asp-for="Title" class="form-control"
                               placeholder="t.ex. Volvo V70 2020 – välskött med låg miltal" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                        <div class="form-text">Skriv en tydlig titel som beskriver bilen.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Beskrivning</label>
                        <textarea asp-for="Description" class="form-control" rows="5"
                                  placeholder="Beskriv bilens skick, utrustning, servicehistorik m.m."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-semibold">Pris (kr)</label>
                            <div class="input-group">
                                <input asp-for="Price" type="number" class="form-control" min="1"
                                       placeholder="t.ex. 150000" />
                                <span class="input-group-text">kr</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold">Publiceringsstatus</label>
                            <select asp-for="Status" class="form-select">
                                <option value="@((int)Carsure.Models.AdStatus.PUBLISHED)">Publicera direkt</option>
                                <option value="@((int)Carsure.Models.AdStatus.DRAFT)">Spara som utkast</option>
                            </select>
                            <div class="form-text">Utkast syns bara för dig på din profil.</div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="ImageUrlsInput" class="form-label fw-semibold">Bild-URL:er</label>
                        <textarea asp-for="ImageUrlsInput" class="form-control" rows="4"
                                  placeholder="En URL per rad eller separera med komma. Max 10 bilder."></textarea>
                        <span asp-validation-for="ImageUrlsInput" class="text-danger small"></span>
                        <div class="form-text">Stodjer upp till 10 bilder. Endast http/https-lankar.</div>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-dark px-4 fw-semibold">
                        Publicera annons
                    </button>
                    <a asp-controller="User" asp-action="Profile" class="btn btn-outline-secondary px-4">
                        Avbryt
                    </a>
                </div>

            </form>
        </div>
    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('RegNumber')?.addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    </script>
}
