@model IEnumerable<Carsure.Models.Ad>
@using System.Text.Json

@{
    ViewData["Title"] = "Ads";
    var adCards = Model.Select(ad => new
    {
        id = ad.Id,
        title = ad.Title,
        price = ad.Price,
        shortDescription = ad.Description,
        year = ad.Car.Year,
        mileage = ad.Car.MileAge,
        imageUrl = ad.ImageUrl,
        detailsUrl = Url.Action("Details", "Ad", new { id = ad.Id })
    }).ToList();

    var adCardsJson = JsonSerializer.Serialize(adCards);
}

<section class="ads-page">
    <div class="ads-hero">
        <div>
            <span class="ads-eyebrow">Marketplace</span>
            <h1 class="ads-title">Available car ads</h1>
            <p class="ads-subtitle">Browse recent listings and compare price, condition, and posting date at a glance.
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="ads-empty-state">
            <h2>No ads available</h2>
            <p>There are no car ads to show right now.</p>
        </div>
    }
    else
    {
        <div id="ad-list-react-root"></div>
        <script id="ad-list-data" type="application/json">@Html.Raw(adCardsJson)</script>
    }
</section>

@section Scripts {
    <script type="module" src="~/dist/ad-card-list.js" asp-append-version="true"></script>
}
