@model Carsure.Models.Ad
@using System.Text.Json

@{
    ViewData["Title"] = Model.Title;
    var isAdmin = Context.Session.GetString("UserRole") == "Admin";
    var currentUserId = Context.Session.GetInt32("UserId");
    var isOwner = currentUserId.HasValue && Model.UserId == currentUserId.Value;
    var canDelete = isAdmin || isOwner;
    var isLoggedIn = currentUserId.HasValue;
    var canContact = isLoggedIn && !isOwner && Model.User != null;
    var imageUrls = Model.GetImageUrls();

    var adCard = new[]
    {
        new
        {
            id = Model.Id,
            title = Model.Title,
            price = Model.Price,
            shortDescription = Model.Description,
            brand = Model.Car.Brand,
            model = Model.Car.Model,
            year = Model.Car.Year,
            mileage = Model.Car.MileAge,
            city = Model.City,
            region = Model.Region,
            imageUrl = Model.ImageUrl,
            imageUrls,
            detailsUrl = Url.Action("Details", "Ad", new { id = Model.Id }),
            hideDetailsButton = true,
            enableImagePicker = true
        }
    };
    var adCardJson = JsonSerializer.Serialize(adCard);
}

<section class="ads-page mb-5">

    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div id="ad-list-react-root"></div>

    <article class="ad-card mt-4">

        
        @if (canContact)
        {
            <div class="ad-card__contact">
                <div class="ad-card__contact-info">
                    <span class="ad-card__contact-label">Säljarens e-post</span>
                    <a href="mailto:@Model.User!.Email" class="ad-card__contact-email">@Model.User!.Email</a>
                </div>
                <a asp-controller="Ad" asp-action="ContactSeller" asp-route-id="@Model.Id" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1"
                         viewBox="0 0 16 16">
                        <path
                        d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z" />
                    </svg>
                    Kontakta säljaren
                </a>
            </div>
        }
        else if (!isLoggedIn)
        {
            <div class="ad-card__contact ad-card__contact--guest">
                <p class="mb-2 text-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1"
                         viewBox="0 0 16 16">
                        <path
                        d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                    </svg>
                    Logga in för att kontakta säljaren
                </p>
                <a asp-controller="User" asp-action="Login" class="btn btn-outline-primary btn-sm">
                    Logga in
                </a>
            </div>
        }

        @if (canDelete)
        {
            <div class="ad-card__footer">
                <div class="d-flex gap-2 align-items-center">
                    <a asp-controller="Ad" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                        ✏️ Ändra annons
                    </a>
                    <form asp-controller="Ad" asp-action="Delete" method="post" class="d-inline"
                          onsubmit="return confirm('Är du säker på att du vill ta bort denna annons?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Ta bort annons</button>
                    </form>
                </div>
            </div>
        }
    </article>
</section>

<script>window.__adListData = @Html.Raw(adCardJson);</script>

@section Scripts {
    <script type="module" src="~/dist/ad-card-list.js" asp-append-version="true"></script>
}
