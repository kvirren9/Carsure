@model IEnumerable<Carsure.Models.User>

@{
    ViewData["Title"] = "Admin – Användare";
}

<section class="ads-page">
    <div class="ads-hero">
        <div>
            <span class="ads-eyebrow">Administration</span>
            <h1 class="ads-title">Användare</h1>
            <p class="ads-subtitle">Hantera användare och deras roller.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Tillbaka till annonser</a>
    </div>

    @if (!Model.Any())
    {
        <div class="ads-empty-state">
            <h2>Inga användare</h2>
            <p>Det finns inga registrerade användare.</p>
        </div>
    }
    else
    {
        var currentUserId = Context.Session.GetInt32("UserId");

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Namn</th>
                        <th>E-post</th>
                        <th>Roll</th>
                        <th>Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Name</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.Role == Carsure.Models.UserRole.Admin ? "bg-danger" : "bg-primary")">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                @if (user.Id != currentUserId)
                                {
                                    <form asp-controller="Admin" asp-action="SetUserRole" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        @if (user.Role == Carsure.Models.UserRole.User)
                                        {
                                            <input type="hidden" name="role" value="@((int)Carsure.Models.UserRole.Admin)" />
                                            <button type="submit" class="btn btn-warning btn-sm"
                                                    onclick="return confirm('Gör @user.Name till Admin?');">
                                                Gör till Admin
                                            </button>
                                        }
                                        else
                                        {
                                            <input type="hidden" name="role" value="@((int)Carsure.Models.UserRole.User)" />
                                            <button type="submit" class="btn btn-secondary btn-sm"
                                                    onclick="return confirm('Degradera @user.Name till User?');">
                                                Gör till User
                                            </button>
                                        }
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Du</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>