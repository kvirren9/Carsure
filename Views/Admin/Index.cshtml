@model IEnumerable<Carsure.Models.Ad>

@{
    ViewData["Title"] = "Admin – Alla annonser";
}

<section class="ads-page">
    <div class="ads-hero">
        <div>
            <span class="ads-eyebrow">Administration</span>
            <h1 class="ads-title">Alla annonser</h1>
            <p class="ads-subtitle">Hantera samtliga annonser i systemet.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3">
        <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">Hantera användare</a>
    </div>

    @if (!Model.Any())
    {
        <div class="ads-empty-state">
            <h2>Inga annonser</h2>
            <p>Det finns inga annonser i systemet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Titel</th>
                        <th>Pris</th>
                        <th>Status</th>
                        <th>Ägare</th>
                        <th>Skapad</th>
                        <th>Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ad in Model)
                    {
                        <tr>
                            <td>@ad.Id</td>
                            <td>@ad.Title</td>
                            <td>@ad.Price.ToString("C")</td>
                            <td>
                                <span class="badge @(ad.Status == Carsure.Models.AdStatus.PUBLISHED ? "bg-success" : ad.Status == Carsure.Models.AdStatus.DRAFT ? "bg-secondary" : "bg-warning text-dark")">
                                    @ad.Status
                                </span>
                            </td>
                            <td>@(ad.User?.Name ?? "–")</td>
                            <td>@ad.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <form asp-controller="Admin" asp-action="DeleteAd" method="post" class="d-inline"
                                      onsubmit="return confirm('Är du säker på att du vill ta bort denna annons?');">
                                    <input type="hidden" name="id" value="@ad.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Ta bort</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>